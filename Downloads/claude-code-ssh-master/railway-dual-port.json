{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "./Dockerfile",
    "watchPatterns": [
      "Dockerfile",
      "sshd_config",
      "banner.txt",
      "tmux.conf",
      "scripts/**",
      "s6-overlay/**",
      "fail2ban/**",
      "web-ui/backend/**"
    ]
  },
  "deploy": {
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "ports": [
      {
        "port": 22,
        "type": "TCP"
      },
      {
        "port": 8080,
        "type": "HTTP"
      }
    ]
  }
}
